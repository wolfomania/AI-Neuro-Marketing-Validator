# Required: Anthropic API key for Claude analysis
NM_ANTHROPIC_API_KEY=sk-ant-...

# Required: HuggingFace token for TRIBE v2 model download (LLaMA 3.2-3B)
NM_HF_TOKEN=hf_...

# Optional: Override defaults
# NM_TRIBE_CACHE_FOLDER=./cache
# NM_UPLOAD_DIR=./uploads
# NM_RESULTS_DIR=./results
# NM_MAX_VIDEO_DURATION_SECONDS=60
# NM_MIN_VIDEO_DURATION_SECONDS=15
# NM_MAX_VIDEO_SIZE_MB=100
# NM_TOP_K_ROIS=20
# NM_CLAUDE_MODEL=claude-sonnet-4-20250514
# NM_CORS_ORIGINS=http://localhost:5173
